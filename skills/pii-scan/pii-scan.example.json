{
  "_comment": "Copy to .pii-scan.json in the directory you scan. Allowlist entries use the object form so every exception carries its own audit trail.",
  "fail_on": "medium",
  "allowlist": [
    {
      "value": "press@yourdomain.example",
      "why": "published contact address, intentionally public",
      "added": "2026-01-01"
    }
  ],
  "allowlist_patterns": [
    "@yourdomain\\.example$"
  ],
  "custom_patterns": [
    {
      "name": "member-id",
      "pattern": "MBR-\\d{6,10}",
      "confidence": "high"
    }
  ],
  "exclude_paths": [
    "test/fixtures/"
  ],
  "max_bytes": 2097152
}
