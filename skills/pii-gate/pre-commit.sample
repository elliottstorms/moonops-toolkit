#!/bin/sh
# pre-commit.sample - refuse to commit staged content containing PII.
# Install into a repo:
#   cp skills/pii-gate/pre-commit.sample .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
# Scans the STAGED blobs (git show :file), not the working tree, so the thing
# that gets checked is exactly the thing that would be committed.
# Note: filenames containing spaces are not handled by this sample.
set -eu

SCANNER="${PII_SCANNER:-$HOME/.claude/skills/pii-scan/pii_scan.py}"
if [ ! -f "$SCANNER" ]; then
  echo "pii-gate: scanner not found at $SCANNER (set PII_SCANNER); allowing" >&2
  exit 0
fi

files=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$files" ] && exit 0

status=0
for f in $files; do
  git show ":$f" | python3 "$SCANNER" --mode gate --stdin || {
    echo "pii-gate: blocked commit of $f" >&2
    status=2
  }
done

if [ "$status" -ne 0 ]; then
  echo "pii-gate: fix the findings, add auditable allowlist entries, or redact, then re-stage." >&2
fi
exit $status
