{
  "skipWorkflowUsageWarning": true,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/you/.claude/bin/site-link-check.sh",
            "timeout": 30,
            "statusMessage": "Checking site links..."
          },
          {
            "type": "command",
            "command": "/Users/you/.claude/bin/em-dash-check.sh",
            "timeout": 15,
            "statusMessage": "Checking public copy for em dashes..."
          },
          {
            "type": "command",
            "command": "/Users/you/.claude/bin/backup-after-asset.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/you/.claude/bin/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
