{
  "skipWorkflowUsageWarning": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/you/.claude/bin/git-add-guard.sh",
            "timeout": 10,
            "statusMessage": "Checking git add safety..."
          }
        ]
      },
      {
        "matcher": "Write|Edit|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/you/.claude/bin/pii-gate-hook.sh",
            "timeout": 15,
            "statusMessage": "PII gate..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/you/.claude/bin/site-link-check.sh",
            "timeout": 30,
            "statusMessage": "Checking site links..."
          },
          {
            "type": "command",
            "command": "/Users/you/.claude/bin/em-dash-check.sh",
            "timeout": 15,
            "statusMessage": "Checking public copy for em dashes..."
          },
          {
            "type": "command",
            "command": "/Users/you/.claude/bin/frontmatter-check.sh",
            "timeout": 15,
            "statusMessage": "Validating skill frontmatter..."
          },
          {
            "type": "command",
            "command": "/Users/you/.claude/bin/backup-after-asset.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/you/.claude/bin/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/you/.claude/bin/session-end-capture.sh",
            "timeout": 20,
            "statusMessage": "Capturing session for self-heal..."
          }
        ]
      }
    ]
  }
}
